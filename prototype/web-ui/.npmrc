# The prototype pulls two independent toolchains (Nuxt's Vite and Storybook's
# Vite) into one isolated install. Their peer-dependency ranges on `vite` do not
# always overlap exactly, which makes a strict npm resolver abort with ERESOLVE.
# This prototype is a throwaway sandbox (not a published package), so we relax the
# resolver here. This file is scoped to prototype/web-ui only and never affects the
# repo-root install.
legacy-peer-deps=true
