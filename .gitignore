node_modules/
dist/
coverage/

# packages/core/dist IS committed: the package is consumed as a private git
# dependency (no npm publish), a git install never receives devDependencies
# (so it cannot build itself), and pnpm/bun block lifecycle scripts of git
# deps by default — the committed dist/ is what consumers resolve against.
# Rebuild it (bun run build in packages/core) whenever src/ changes.
!packages/core/dist/
!packages/core/dist/**
.sdlc/
*.log
.DS_Store
.rumdl_cache/

# --- Claude Code project-local ---
# Default: ignore everything inside .claude/ ...
.claude/*
# ... then explicitly un-ignore the shareable bits.
!.claude/settings.json
!.claude/skills/
!.claude/commands/
!.claude/agents/
!.claude/hooks.json
!.claude/hooks/
!.claude/hooks/**

# --- SDLC plugin project-local ---
.sdlc/*
!.sdlc/skill-ext/
!.sdlc/skill-ext/**

# moon
.moon/cache
.moon/docker

# sites/docs — Astro + Starlight site build artifacts (T-7UTE). node_modules/ and
# dist/ are already covered by the global patterns above; listed explicitly per
# AC-4, and .astro/ (Astro's generated cache/types dir) is the load-bearing add.
sites/docs/node_modules/
sites/docs/dist/
sites/docs/.astro/

# sites/docs — generated catalog pages (T-SITE): rendered from docs/catalog/*.yaml
# by sites/docs/scripts/generate.ts. The YAML is the single source of truth; the
# emitted pages (including the landing) are build artifacts, never hand-edited.
sites/docs/src/content/docs/index.md
sites/docs/src/content/docs/examples/
# scratch dir of the artifact regression check (sites/docs/scripts/check-artifacts.ts)
sites/docs/.artifact-check/

# Obsidian local vault config (docs/ is opened as a personal vault)
docs/.obsidian/
# Obsidian "Bases" view definitions (personal, generated locally)
*.base

# Bun is the canonical dev package manager (T-WKSP / D-0010 D1): bun.lock IS
# committed. npm stays canonical for the PUBLISHED artifact only (packages/core),
# so a root package-lock.json must never be committed.
/package-lock.json

# Nuxt build outputs (apps/web/ui)
.nuxt/
.output/
# Nuxt dev symlink (ui/dist -> .nuxt/dist)
apps/web/ui/dist
