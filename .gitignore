# --- Claude Code project-local ---
# Default: ignore everything inside .claude/ ...
.claude/*
# ... then explicitly un-ignore the shareable bits.
!.claude/settings.json
!.claude/skills/
!.claude/commands/
!.claude/agents/
!.claude/hooks.json
!.claude/hooks/
!.claude/hooks/**

# --- SDLC plugin project-local ---
.sdlc/*
!.sdlc/skill-ext/
!.sdlc/skill-ext/**

# moon
.moon/cache
.moon/docker

# Obsidian local vault config (docs/ is opened as a personal vault)
docs/.obsidian/
# Obsidian "Bases" view definitions (personal, generated locally)
*.base

# Bun is the canonical dev package manager (T-WKSP / D-0010 D1): bun.lock IS
# committed. npm stays canonical for the PUBLISHED artifact only (packages/core),
# so a root package-lock.json must never be committed.
/package-lock.json

# Nuxt build outputs (apps/web/ui)
.nuxt/
.output/
# Nuxt dev symlink (ui/dist -> .nuxt/dist)
apps/web/ui/dist
