# Build / tooling artifacts for the daemon-web prototype.
# (Root .gitignore already ignores node_modules/ and dist/ globally; this adds
#  the Nuxt + Storybook output dirs so they never get committed from here.)
node_modules/
.nuxt/
.output/
# `dist` (no slash) also catches the symlink `nuxt generate` creates: dist -> .output/public
dist
.data/
.nitro/
.cache/
storybook-static/
*.log
.DS_Store
