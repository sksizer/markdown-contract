{
  "name": "@markdown-contract/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The markdown-contract web face (D-0012): one combined entry that is the CLI when run bare and a loopback vault-dashboard daemon (Nuxt SPA + JSON API) under `daemon` — the `bun build --compile` target.",
  "bin": {
    "markdown-contract": "./src/bin.ts"
  },
  "scripts": {
    "cli": "bun run src/bin.ts",
    "daemon": "bun run src/bin.ts daemon",
    "ui:dev": "nuxt dev ui",
    "ui:generate": "nuxt generate ui",
    "gen:assets": "bun run scripts/gen-assets.ts",
    "compile": "bun build --compile src/bin.ts --outfile dist/markdown-contract",
    "build:binary": "bun run ui:generate && bun run gen:assets && bun run compile",
    "test": "bun test src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@markdown-contract/dashboard": "workspace:*",
    "@markdown-contract/ui": "workspace:*",
    "markdown-contract": "workspace:*",
    "nuxt": "^4.4.5",
    "vue": "^3.5.34",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "5.9.3",
    "vue-tsc": "3.3.7"
  }
}
