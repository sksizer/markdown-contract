{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/core": {
      "entry": [
        "src/index.ts",
        "src/declarative/index.ts",
        "src/cli/index.ts",
        "vitest.config.ts",
        "src/**/*.test.ts",
        "tests/**/*.test.ts",
        "tests/harness.ts",
        "tests/components.ts",
        "tests/fixtures/**/*.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": ["src/daemon/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts", "types/**/*.ts"],
      "ignoreDependencies": ["vue", "vue-tsc"]
    }
  },
  "ignoreWorkspaces": ["apps/daemon-web-prototype"],
  "ignoreDependencies": [],
  "ignoreBinaries": []
}
