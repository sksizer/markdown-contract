{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/core": {
      "entry": [
        "src/index.ts",
        "src/declarative/index.ts",
        "src/cli/index.ts",
        "src/**/*.test.ts",
        "tests/**/*.test.ts",
        "tests/harness.ts",
        "tests/components.ts",
        "tests/fixtures/**/*.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["vue"]
    },
    "apps/web": {
      "entry": ["src/daemon/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts", "types/**/*.ts"],
      "ignoreDependencies": [
        "@markdown-contract/dashboard",
        "@markdown-contract/ui",
        "vue",
        "vue-tsc"
      ]
    },
    "apps/desktop": {
      "ignore": ["app/assets/**", "app/bindings/**"],
      "ignoreDependencies": [
        "@markdown-contract/ui",
        "@tauri-apps/plugin-opener",
        "vue-router",
        "vue-tsc"
      ]
    },
    "packages/dashboard": {
      "entry": [
        "nuxt.config.ts",
        "pages/**/*.vue",
        "composables/**/*.ts",
        "transport.ts",
        "scripts/**/*.ts"
      ],
      "project": ["**/*.{ts,vue}"],
      "ignore": ["bindings/**"],
      "ignoreDependencies": ["nuxt", "vue"]
    }
  },
  "ignoreWorkspaces": [],
  "ignoreDependencies": [],
  "ignoreBinaries": ["scc"]
}
