{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/core": {
      "entry": [
        "src/index.ts",
        "src/declarative/index.ts",
        "src/cli/index.ts",
        "src/**/*.test.ts",
        "tests/**/*.test.ts",
        "tests/harness.ts",
        "tests/components.ts",
        "tests/fixtures/**/*.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["vue"]
    },
    "apps/web": {
      "entry": ["src/daemon/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts", "types/**/*.ts"],
      "ignoreDependencies": ["@markdown-contract/ui", "vue", "vue-tsc"]
    }
  },
  "ignoreWorkspaces": [],
  "ignoreDependencies": [],
  "ignoreBinaries": ["scc"]
}
